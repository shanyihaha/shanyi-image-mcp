# 复制为 .env，填入 key
MICU_API_KEY=sk-...
MICU_BASEURL=https://www.micuapi.ai
MICU_MODEL=gpt-image-2

# 可选：米醋 Grok 图像通道
MICU_GROK_API_KEY=sk-...
XAI_MODEL=grok-imagine-image-lite
# Grok 后端不保证精确 WxH；MCP 可在保存前后处理到请求尺寸。
# 可选: contain(默认，补边不裁切) / cover(裁切铺满) / stretch(拉伸) / backend(保留后端原图)
MICU_GROK_SIZE_MODE=contain

# 输出目录（不填默认 ~/Pictures/micu-out）
# macOS / Linux:
MICU_SAVE_DIR=~/Pictures/micu-out
MICU_SAVE_DIR_ROOT=~/Pictures/micu-out
# Windows (cmd / pwsh):
# MICU_SAVE_DIR=%USERPROFILE%\Pictures\micu-out
# MICU_SAVE_DIR_ROOT=%USERPROFILE%\Pictures\micu-out
