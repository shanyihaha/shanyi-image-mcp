# 复制为 .env，填入 key
SHANYI_API_KEY=sk-...
SHANYI_BASEURL=https://shanyiapi.com
SHANYI_MODEL=gpt-image-2

# 输出目录（不填默认 ~/Pictures/shanyi-image-out）
# macOS / Linux:
SHANYI_SAVE_DIR=~/Pictures/shanyi-image-out
SHANYI_SAVE_DIR_ROOT=~/Pictures/shanyi-image-out
# Windows (cmd / pwsh):
# SHANYI_SAVE_DIR=%USERPROFILE%\Pictures\shanyi-image-out
# SHANYI_SAVE_DIR_ROOT=%USERPROFILE%\Pictures\shanyi-image-out
